VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Your deployed app URL — used for magic link and OAuth redirects
VITE_APP_URL=https://your-app.vercel.app
# Google OAuth Client ID — required for "Google Contacts" import tab
# Create at console.cloud.google.com → APIs & Services → Credentials
# Enable the Google People API and add your Vercel domain to authorized origins
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# --- Server-side only (NO "VITE_" prefix — never exposed to browser bundle) ---
# Base URL for n8n Cloud instance, used by the /api/n8n-webhook proxy.
# Set this in Vercel dashboard: Settings → Environment Variables
N8N_BASE_URL=https://amiralda.app.n8n.cloud
